# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://kite360:changeme@db:5432/kite360
DB_PASSWORD=changeme

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_use_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ───────────────────────────────────────────────────
API_PORT=3000
API_URL=https://kite360.com.br

# ─── Frontend ──────────────────────────────────────────────
VITE_API_URL=https://kite360.com.br/api/v1
VITE_WS_URL=wss://kite360.com.br

# ─── Admin (emails separados por vírgula) ───────────────────
ADMIN_EMAILS=admin@kite360.com.br

# ─── Mercado Pago ──────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── LibreTranslate ────────────────────────────────────────
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_API_KEY=

# ─── Upload ────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_BYTES=10485760

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── NODE ──────────────────────────────────────────────────
NODE_ENV=production